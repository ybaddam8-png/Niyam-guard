# Copy to .env and fill in real values. Never commit .env to git (already in .gitignore).

# --- LLM provider ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
REQUEST_TIMEOUT_SECONDS=30

# --- Database (real Postgres, not SQLite) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/niyamguard

# --- Auth ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of exact frontend origins, e.g. http://localhost:5173,https://niyamguard.example.gov.in
ALLOWED_ORIGINS=http://localhost:5173

# --- Rate limiting ---
EXTRACTION_RATE_LIMIT=5/minute
